{
  "_comment": "Backend API contract for PrepAI. Frontend sends these requests; backend should respond with these shapes.",

  "POST /api/users/sync": {
    "description": "Called by useUserSync hook after every Clerk sign-in/sign-up. Creates user if new, updates lastSeen if existing.",
    "request": {
      "body": {
        "clerkId": "user_2abc123xyz",
        "email": "user@example.com",
        "firstName": "Arjun",
        "lastName": "Mehta",
        "imageUrl": "https://img.clerk.com/...",
        "provider": "email_code",
        "createdAt": "2025-06-22T10:30:00.000Z"
      }
    },
    "response_201_new_user": {
      "id": "usr_01j9abc123",
      "clerkId": "user_2abc123xyz",
      "email": "user@example.com",
      "firstName": "Arjun",
      "lastName": "Mehta",
      "imageUrl": "https://img.clerk.com/...",
      "plan": "free",
      "interviewsUsed": 0,
      "interviewsLimit": 3,
      "createdAt": "2025-06-22T10:30:00.000Z",
      "updatedAt": "2025-06-22T10:30:00.000Z",
      "isNew": true
    },
    "response_200_existing_user": {
      "id": "usr_01j9abc123",
      "clerkId": "user_2abc123xyz",
      "email": "user@example.com",
      "firstName": "Arjun",
      "lastName": "Mehta",
      "imageUrl": "https://img.clerk.com/...",
      "plan": "pro",
      "interviewsUsed": 14,
      "interviewsLimit": -1,
      "createdAt": "2025-06-10T08:00:00.000Z",
      "updatedAt": "2025-06-22T10:30:00.000Z",
      "isNew": false
    }
  },

  "GET /api/users/me": {
    "description": "Fetch the current user's profile and usage stats. Requires auth header.",
    "headers": {
      "Authorization": "Bearer <clerk_session_token>"
    },
    "response_200": {
      "id": "usr_01j9abc123",
      "clerkId": "user_2abc123xyz",
      "email": "user@example.com",
      "firstName": "Arjun",
      "lastName": "Mehta",
      "imageUrl": "https://img.clerk.com/...",
      "plan": "pro",
      "interviewsUsed": 14,
      "interviewsLimit": -1,
      "totalInterviews": 14,
      "avgScore": 78,
      "createdAt": "2025-06-10T08:00:00.000Z"
    }
  },

  "POST /api/interviews": {
    "description": "Start a new interview session. Returns a session ID used to open the WebSocket.",
    "headers": {
      "Authorization": "Bearer <clerk_session_token>"
    },
    "request": {
      "body": {
        "role": "software_engineer",
        "level": "mid",
        "focusAreas": ["system_design", "behavioral", "coding"]
      }
    },
    "roles": ["software_engineer", "product_manager", "data_scientist", "ux_designer", "backend_engineer", "frontend_engineer"],
    "levels": ["junior", "mid", "senior", "staff"],
    "response_201": {
      "id": "iv_01j9xyz789",
      "userId": "usr_01j9abc123",
      "role": "software_engineer",
      "level": "mid",
      "focusAreas": ["system_design", "behavioral", "coding"],
      "status": "in_progress",
      "wsUrl": "ws://localhost:8000/ws?session=iv_01j9xyz789",
      "createdAt": "2025-06-22T11:00:00.000Z"
    }
  },

  "PATCH /api/interviews/:id": {
    "description": "Update interview after session ends — save transcript and trigger AI feedback generation.",
    "headers": {
      "Authorization": "Bearer <clerk_session_token>"
    },
    "request": {
      "body": {
        "status": "completed",
        "durationSeconds": 1245,
        "transcript": [
          { "speaker": "ai",   "text": "Tell me about yourself.", "timestamp": "2025-06-22T11:01:00.000Z" },
          { "speaker": "user", "text": "I'm a software engineer with 4 years of experience...", "timestamp": "2025-06-22T11:01:05.000Z" }
        ]
      }
    },
    "response_200": {
      "id": "iv_01j9xyz789",
      "status": "completed",
      "durationSeconds": 1245,
      "transcript": "...(full transcript)...",
      "feedback": {
        "overallScore": 82,
        "clarity": 85,
        "technicalAccuracy": 78,
        "confidence": 80,
        "strengths": [
          "Strong STAR format in behavioral answers",
          "Good use of specific metrics"
        ],
        "improvements": [
          "System design answer lacked scalability discussion",
          "Could be more concise in introductions"
        ],
        "summary": "Overall strong performance. Focus on depth in system design questions."
      },
      "updatedAt": "2025-06-22T11:21:00.000Z"
    }
  },

  "GET /api/interviews": {
    "description": "List all interviews for the current user, newest first.",
    "headers": {
      "Authorization": "Bearer <clerk_session_token>"
    },
    "query": {
      "page": 1,
      "limit": 10
    },
    "response_200": {
      "interviews": [
        {
          "id": "iv_01j9xyz789",
          "role": "software_engineer",
          "level": "mid",
          "status": "completed",
          "durationSeconds": 1245,
          "overallScore": 82,
          "createdAt": "2025-06-22T11:00:00.000Z"
        }
      ],
      "total": 14,
      "page": 1,
      "limit": 10
    }
  },

  "GET /api/interviews/:id": {
    "description": "Get full details for a single interview including transcript and feedback.",
    "headers": {
      "Authorization": "Bearer <clerk_session_token>"
    },
    "response_200": {
      "id": "iv_01j9xyz789",
      "userId": "usr_01j9abc123",
      "role": "software_engineer",
      "level": "mid",
      "focusAreas": ["system_design", "behavioral"],
      "status": "completed",
      "durationSeconds": 1245,
      "transcript": [
        { "speaker": "ai",   "text": "Tell me about yourself.", "timestamp": "2025-06-22T11:01:00.000Z" },
        { "speaker": "user", "text": "I'm a software engineer with 4 years...", "timestamp": "2025-06-22T11:01:05.000Z" }
      ],
      "feedback": {
        "overallScore": 82,
        "clarity": 85,
        "technicalAccuracy": 78,
        "confidence": 80,
        "strengths": ["Strong STAR format", "Good use of metrics"],
        "improvements": ["Deepen system design answers"],
        "summary": "Overall strong performance."
      },
      "createdAt": "2025-06-22T11:00:00.000Z",
      "updatedAt": "2025-06-22T11:21:00.000Z"
    }
  }
}
